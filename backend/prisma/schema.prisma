generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Student {
  id         Int           @id @default(autoincrement())
  fullName   String
  course     Int
  group      String
  phone      String?
  roomId     Int?
  room       Room?         @relation(fields: [roomId], references: [id])
  bedNumber  Int?
  status     StudentStatus @default(PENDING)
  movedIn    DateTime?
  movedOut   DateTime?

  suspiciousBookings Booking[] @relation("SuspiciousMatch")

  payments   Payment[]
  absences   Absence[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Payment {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  month     Int
  year      Int
  amount    Int
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([studentId, month, year])
}

model PaymentConfig {
  id        Int      @id @default(autoincrement())
  amount    Int
  updatedAt DateTime @updatedAt
}

model Booking {
  id        Int           @id @default(autoincrement())
  fullName  String
  course    Int
  group     String
  phone     String?
  roomId    Int
  room      Room          @relation(fields: [roomId], references: [id])
  bedNumber Int
  status    BookingStatus @default(PENDING)

  similarStudentId Int?
  similarStudent   Student? @relation("SuspiciousMatch", fields: [similarStudentId], references: [id])

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Room {
  id          Int       @id @default(autoincrement())
  number      Int       @unique
  floor       Int
  totalBeds   Int
  type        RoomType  @default(RESIDENTIAL)
  students    Student[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum RoomType {
  RESIDENTIAL
  NON_RESIDENTIAL
  TOILET
  TECH
}

enum StudentStatus {
  PENDING
  ACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum AbsenceStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model Absence {
  id        Int            @id @default(autoincrement())
  studentId Int
  student   Student        @relation(fields: [studentId], references: [id])
  startDate DateTime
  endDate   DateTime
  reason    String
  status    AbsenceStatus  @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
